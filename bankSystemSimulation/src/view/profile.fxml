<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="TOP_LEFT"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ProfileController">

    <Label text="Profile" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    

    <VBox spacing="10" alignment="TOP_LEFT" fx:id="resultBox" visible="false" managed="false">

        

        <Label fx:id="lblUserId" style="-fx-font-size: 16px;"/>
      	<Label fx:id="lblUsername"/>
      	<Label fx:id="lblFullName"/>

      	<Label text="Accounts:"/>
      	<VBox alignment="TOP_LEFT" spacing="10">
    		<ListView fx:id="accountList" prefWidth="150" prefHeight="100" maxWidth="150" maxHeight="100"/>
		</VBox>

    </VBox>

</VBox>